{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["dom", "ESNext"],
    "sourceMap": true,
    "noEmitHelpers": true,
    "importHelpers": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["app/*"],
      "@/*": ["app/*"]
    },
    "typeRoots": ["types", "node_modules/@types", "node_modules/@nativescript"],
    "types": ["node", "@nativescript/core", "nativescript-vue"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true
  },
  "include": ["app", "types", "references.d.ts"],
  "exclude": ["node_modules", "platforms"]
}